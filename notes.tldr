						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "ans - suppose a user uses the app for 20H and then it sleeps for the 8H so for the next day the refresh token will be expired and it will require login again on next day "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "but if you want that it should be extended then you have to update the refresh token which is generally used because 24Hour Time period starts with the new req   "
								}
							]
						}
					]
				}
			},
