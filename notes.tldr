		{
			"x": -1457.5237198435625,
			"y": 10315.380017393318,
			"rotation": 0,
			"isLocked": false,
			"opacity": 1,
			"meta": {},
			"id": "shape:eKmu4O1vSNmOdJVNPSxXL",
			"type": "text",
			"props": {
				"color": "black",
				"size": "m",
				"w": 2070.769775390625,
				"font": "draw",
				"textAlign": "start",
				"autoSize": true,
				"scale": 1,
				"richText": {
					"type": "doc",
					"attrs": {
						"dir": "auto"
					},
					"content": [
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "user tries for a sevice and request for it for eg /cart with access token which was not accepted because access token was expired "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "when the access token is expired and you sre sending the request backend will give you the unique status code (206)"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "at the frontend i know when status code (206) comes basically on expire of the access token "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "then i will send the refresh token in my request on the /refresh endpoint (backend) "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "=> first i will check the refresh token in the DB whether you have the refresh token or not if yes then i will check if its valid (24Hour) or not  "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "if yess from there backend will generate the fresh access token and fresh refresh token which will be sent to the client and update the refresh token in the DB also"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "and then again retries the first request "
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "b0hQNpZUl",
			"typeName": "shape"
		},
