						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- user will enter the emailId(unique identifier - mobile) "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- we will use findbyId({email}) and find the user in DB "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- if not found throw error "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- if found then we will create and send the token to the user via email/whatsapp and another one in the DB (field: resetPasswordToken) and the token expiry time (resetPasswordExpires)"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- now we can show the user the enter otp page or if via email then user will just bring the token at /new-password"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "- new-password service will match for the token and expiry if matched then we will take new-password from the user and also update it in the DB and then redirect to the /login"
								}
							]
						}
					]
				}
			},
